#!/usr/bin/env bash
set -euo pipefail

cpp_files=()
cmake_files=()

while IFS= read -r -d '' file; do
  case "$file" in
    *.c|*.cc|*.cpp|*.cxx|*.h|*.hh|*.hpp|*.hxx)
      cpp_files+=("$file")
      ;;
    */CMakeLists.txt|CMakeLists.txt|*.cmake)
      cmake_files+=("$file")
      ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if ((${#cpp_files[@]})); then
  clang-format -i "${cpp_files[@]}"
  git add -- "${cpp_files[@]}"
fi

if ((${#cmake_files[@]})); then
  cmake-format -i "${cmake_files[@]}"
  git add -- "${cmake_files[@]}"
fi
